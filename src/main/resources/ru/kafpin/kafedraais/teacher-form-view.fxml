<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="400.0" spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.kafpin.kafedraais.controllers.TeacherFormController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="ФИО преподавателя:" />
    <TextField fx:id="nameField" promptText="Иванов Иван Иванович" />

    <Label text="Должность:" />
    <TextField fx:id="positionField" promptText="Доцент, Профессор и т.д." />

    <Label text="Ученая степень:" />
    <TextField fx:id="degreeField" promptText="к.т.н., д.т.н." />

    <Label text="Email:" />
    <TextField fx:id="emailField" promptText="example@uni.ru" />

    <Label text="Секция (кафедра):" />
    <ComboBox fx:id="sectionComboBox" prefWidth="400.0" promptText="Выберите секцию" />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <padding>
            <Insets top="15.0" />
        </padding>
        <Button mnemonicParsing="false" onAction="#handleCancel" text="Отмена" />
        <Button mnemonicParsing="false" onAction="#handleSave" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Сохранить" />
    </HBox>
</VBox>
