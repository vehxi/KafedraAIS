<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.kafpin.kafedraais.controllers.MainController">
    <children>
        <VBox style="-fx-background-color: #2196F3;">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            <Label text="Панель администратора АИС «Кафедра»" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="20.0" />
                </font>
            </Label>
        </VBox>
        <TabPane fx:id="mainTabPane" prefHeight="550.0" prefWidth="800.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <Tab text="Секции кафедры">
                    <content>
                        <VBox style="-fx-padding: 10;">
                            <TableView fx:id="sectionsTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="sectionIdCol" prefWidth="50.0" text="ID" />
                                    <TableColumn fx:id="sectionNameCol" prefWidth="250.0" text="Название секции" />
                                    <TableColumn fx:id="sectionDescCol" prefWidth="400.0" text="Описание" />
                                </columns>
                            </TableView>
                            <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                <Button text="Добавить секцию" onAction="#handleAddSection" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                                <Button text="Редактировать" onAction="#handleEditSection" />
                                <Button text="Удалить" onAction="#handleDeleteSection" style="-fx-background-color: #F44336; -fx-text-fill: white;" />
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Преподаватели">
                    <content>
                        <VBox style="-fx-padding: 10;">
                            <TableView fx:id="teachersTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="teacherIdCol" prefWidth="50.0" text="ID" />
                                    <TableColumn fx:id="teacherNameCol" prefWidth="250.0" text="ФИО" />
                                    <TableColumn fx:id="teacherPositionCol" prefWidth="150.0" text="Должность" />
                                    <TableColumn fx:id="teacherDegreeCol" prefWidth="150.0" text="Ученая степень" />
                                </columns>
                            </TableView>
                            <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                                <Button text="Добавить преподавателя" onAction="#handleAddTeacher" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
                                <Button text="Редактировать" onAction="#handleEditTeacher" />
                                <Button text="Удалить" onAction="#handleDeleteTeacher" style="-fx-background-color: #F44336; -fx-text-fill: white;" />
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Дисциплины (Курсы)">
                    <content>
                        <VBox style="-fx-padding: 10;">
                            <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="courseIdCol" prefWidth="50.0" text="ID" />
                                    <TableColumn fx:id="courseNameCol" prefWidth="300.0" text="Название" />
                                    <TableColumn fx:id="courseSemesterCol" prefWidth="100.0" text="Семестр" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>
